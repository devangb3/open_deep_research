OPENAI_API_KEY=
# Optional: Set for OpenAI-compatible providers (e.g., OpenRouter)
OPENAI_BASE_URL=
OPENAI_API_BASE=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=

# Optional ODR adapter search configuration
ODR_SEARCH_API=tavily
ODR_OPENROUTER_WEB_SEARCH_ENGINE=auto
# ODR_OPENROUTER_WEB_SEARCH_MAX_RESULTS=5
# ODR_OPENROUTER_WEB_SEARCH_MAX_TOTAL_RESULTS=20
# ODR_OPENROUTER_WEB_SEARCH_CONTEXT_SIZE=medium
# ODR_OPENROUTER_WEB_SEARCH_ALLOWED_DOMAINS=arxiv.org,nature.com
# ODR_OPENROUTER_WEB_SEARCH_EXCLUDED_DOMAINS=reddit.com

# Only necessary for Open Agent Platform
SUPABASE_KEY=
SUPABASE_URL=
# Should be set to true for a production deployment on Open Agent Platform. Should be set to false otherwise, such as for local development.
GET_API_KEYS_FROM_CONFIG=false
